# Managed by Ansible – do not edit manually
# rsyslog server config: receive logs from serverb

# Load TCP input module
module(load="imtcp")
input(type="imtcp" port="{{ syslog_port }}")

# Store health check log from serverb
if $syslogtag == 'nexcore-health' and \
   $fromhost-ip == '{{ hostvars['serverb']['ansible_default_ipv4']['address'] }}' then {
    action(type="omfile" file="{{ serverb_health_log }}")
    stop
}

# Store system logs from serverb 
if $fromhost-ip == '{{ hostvars['serverb']['ansible_default_ipv4']['address'] }}' then {
    action(type="omfile" file="{{ serverb_sys_log }}")
    stop
}

