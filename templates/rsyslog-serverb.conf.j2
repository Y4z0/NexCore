# Managed by Ansible – do not edit manually
# rsyslog client config: forward all logs to servera

# Forward all syslog messages
*.* action(type="omfwd"
           target="{{ syslog_server }}"
           port="{{ syslog_port }}"
           protocol="{{ syslog_protocol }}"
           action.resumeRetryCount="100"
           queue.type="LinkedList"
           queue.size="10000")

# Forward health check log 
module(load="imfile")
input(type="imfile"
      File="{{ health_log }}"
      Tag="nexcore-health"
      Severity="info"
      Facility="local0"
      PersistStateInterval="10"
      ReadMode="0")

local0.* action(type="omfwd"
               target="{{ syslog_server }}"
               port="{{ syslog_port }}"
               protocol="{{ syslog_protocol }}"
               action.resumeRetryCount="100"
               queue.type="LinkedList"
               queue.size="10000")